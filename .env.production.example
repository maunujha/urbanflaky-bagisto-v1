# =============================================================================
# Urbanflaky — PRODUCTION environment template
# Copy to .env on the production server and fill every blank value.
# Never commit the real .env. Rotate any secret that ever leaks.
# =============================================================================

APP_NAME="Urbanflaky"
APP_ENV=production
APP_KEY=                       # php artisan key:generate (NEVER reuse the dev key)
APP_DEBUG=false
APP_DEBUG_ALLOWED_IPS=
APP_URL=https://urbanflaky.in
APP_ADMIN_URL=admin            # consider a non-default path, e.g. uf-backoffice
APP_TIMEZONE=Asia/Kolkata

APP_LOCALE=en
APP_FALLBACK_LOCALE=en

APP_CURRENCY=INR
APP_DEFAULT_COUNTRY=IN

# Comma-separated IPs/CIDRs of the load balancer / CDN allowed to set
# X-Forwarded-* headers. Leave EMPTY if the app faces clients directly.
# Getting this wrong either enables IP spoofing ('*') or breaks rate limiting.
TRUSTED_PROXIES=

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single,sentry
LOG_LEVEL=warning              # debug logs leak PII and bloat disk in prod

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=                   # dedicated user, NOT root
DB_PASSWORD=
DB_PREFIX=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true     # HTTPS-only cookies
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

# Queued listeners (SMS, Shiprocket order creation, reward coins) MUST run on a
# real queue in production — sync executes them inside the checkout request.
# Requires a running worker: see DEPLOYMENT.md.
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=urbanflaky

REDIS_CLIENT=phpredis          # install the phpredis extension; predis is slower
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# Full-page response cache for home/category/CMS/search GET pages.
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_DRIVER=redis

DEBUGBAR_ENABLED=false

MAIL_MAILER=bagisto-dynamic-smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=587
MAIL_USERNAME=support@urbanflaky.in
MAIL_PASSWORD=

MAIL_FROM_ADDRESS=support@urbanflaky.in
MAIL_FROM_NAME="Urbanflaky"
ADMIN_MAIL_ADDRESS=support@urbanflaky.in
ADMIN_MAIL_NAME="Urbanflaky Admin"
CONTACT_MAIL_ADDRESS=support@urbanflaky.in
CONTACT_MAIL_NAME="Urbanflaky Support"

# --- SMSAlert (DLT) ----------------------------------------------------------
SMSALERT_USERNAME=
SMSALERT_APIKEY=
SMSALERT_SENDER=GABHAE
OTP_EXPIRY_MINUTES=10
ADMIN_PHONE=

# DLT template IDs (same values as dev — they are registered per sender)
SMSALERT_TEMPLATE_OTP=
SMSALERT_TEMPLATE_WELCOME=
SMSALERT_TEMPLATE_REGISTRATION=
SMSALERT_TEMPLATE_ORDER_PLACED=
SMSALERT_TEMPLATE_ORDER_SHIPPED=
SMSALERT_TEMPLATE_ORDER_DELIVERED=
SMSALERT_TEMPLATE_ORDER_CANCELLED=
SMSALERT_TEMPLATE_ORDER_REFUNDED=
SMSALERT_TEMPLATE_REFUND_PROCESSED=
SMSALERT_TEMPLATE_ABANDONED_CART=
SMSALERT_TEMPLATE_ADMIN_INQUIRY=
SMSALERT_TEMPLATE_ADMIN_SIGNUP=
SMSALERT_TEMPLATE_ADMIN_ORDER_STATUS=
SMSALERT_TEMPLATE_ADMIN_NEW_ORDER=

# --- Shiprocket ----------------------------------------------------------------
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_PINCODE=328001
SHIPROCKET_PICKUP_LOCATION=home
SHIPROCKET_WEBHOOK_TOKEN=      # long random string; also set it in Shiprocket panel

# --- Razorpay ------------------------------------------------------------------
# LIVE key id/secret are entered in Admin > Configure > Payment Methods >
# Razorpay (sandbox OFF). Webhook secret comes from Dashboard > Webhooks for
# https://urbanflaky.in/razorpay/payment/webhook (event: payment.captured).
RAZORPAY_WEBHOOK_SECRET=

# --- Sentry --------------------------------------------------------------------
SENTRY_LARAVEL_DSN=
SENTRY_ENVIRONMENT="${APP_ENV}"
SENTRY_SEND_DEFAULT_PII=false  # DPDP: do not ship customer PII to Sentry
SENTRY_TRACES_SAMPLE_RATE=0

# --- Google OAuth ----------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="${APP_URL}/customer/auth/google/callback"

SANCTUM_STATEFUL_DOMAINS=urbanflaky.in,.urbanflaky.in

VITE_APP_NAME=urbanflaky
VITE_HOST=
VITE_PORT=

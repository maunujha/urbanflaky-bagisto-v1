# SECURITY (production): set APP_ENV=production and APP_DEBUG=false before going
# live. APP_DEBUG=true on a public host leaks env vars, credentials and stack
# traces. APP_DEBUG_ALLOWED_IPS can scope debug to specific IPs if ever needed.
APP_NAME=Bagisto
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_DEBUG_ALLOWED_IPS=
APP_URL=http://localhost
APP_ADMIN_URL=admin
APP_TIMEZONE=Asia/Kolkata

# Comma-separated IPs/CIDRs of load balancers or CDN egress allowed to set
# X-Forwarded-* headers. Leave empty when the app faces clients directly.
TRUSTED_PROXIES=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_CURRENCY=INR
APP_DEFAULT_COUNTRY=IN

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=
DB_PREFIX=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# SECURITY (production): set SESSION_SECURE_COOKIE=true so the session cookie is
# only ever sent over HTTPS, and consider SESSION_ENCRYPT=true. Keep these unset
# (or false) for local http:// development.
SESSION_SECURE_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

# Gabha Search — Meilisearch (Laravel Scout)
# Set the admin Search Engine to "Meilisearch" to activate; reindex with
# `php artisan urbanflaky:search:reindex --fresh`.
SCOUT_DRIVER=meilisearch
SCOUT_QUEUE=true
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=
GABHA_SEARCH_ENABLED=true
GABHA_SEARCH_INDEX=products
GABHA_SEARCH_QUEUE_CONNECTION=sync
GABHA_SEARCH_QUEUE=default

CACHE_STORE=file
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

RESPONSE_CACHE_ENABLED=true

MAIL_MAILER=bagisto-dynamic-smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null

MAIL_FROM_ADDRESS=shop@example.com
MAIL_FROM_NAME=Shop
ADMIN_MAIL_ADDRESS=admin@example.com
ADMIN_MAIL_NAME=Admin
CONTACT_MAIL_ADDRESS=contact@example.com
CONTACT_MAIL_NAME=Contact

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_HOST=localhost
VITE_PORT=

# --- Urbanflaky integrations -------------------------------------------------

# SMSAlert (DLT transactional SMS) — template IDs live in config/services.php
SMSALERT_USERNAME=
SMSALERT_APIKEY=
SMSALERT_SENDER=
OTP_EXPIRY_MINUTES=10
ADMIN_PHONE=

# Shiprocket (rates, shipments, tracking)
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
SHIPROCKET_PICKUP_PINCODE=328001
SHIPROCKET_PICKUP_LOCATION=home
SHIPROCKET_WEBHOOK_TOKEN=

# Razorpay — checkout keys are configured in Admin > Payment Methods;
# the webhook secret comes from Dashboard > Webhooks for /razorpay/payment/webhook
RAZORPAY_WEBHOOK_SECRET=

# Google OAuth social login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL="${APP_URL}/customer/auth/google/callback"

# Analytics & Tag Management (defaults committed in config/services.php).
# Override here per-environment; set to an explicit empty value to disable.
GTM_CONTAINER_ID=GTM-TK3MV6Q3
CLARITY_PROJECT_ID=x80ym5sh5u
